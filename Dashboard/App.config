<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!-- Edit server, database, and auth to match your SQL Server instance -->
    <add name="DefaultConnection"
         connectionString="Server=(localdb)\MSSQLLocalDB;Database=Dashboard;Trusted_Connection=True;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
